{
  "font": {
    "description": "绘图字体",
    "type": "string",
    "hint": "设置绘图字体，请将字体文件放置于插件目录下的 assets 文件夹中",
    "default": "cute_font.ttf",
    "obvious_hint": true
  },
  "bg_img": {
    "description": "背景图",
    "type": "string",
    "hint": "设置统计图的背景图，请将背景图文件放置于插件目录下的 assets 文件夹中",
    "default": "bg.jpg",
    "obvious_hint": true
  },
  "delay": {
    "description": "发送延迟",
    "type": "float",
    "hint": "设置发送延迟(s)",
    "default": 1
  },
  "chart_cleanup_seconds": {
    "description": "图表兜底清理时间",
    "type": "int",
    "hint": "统计图发送结束后会立即删除；如果发送中断或删除失败，残留图片会在下一次生成图表时按此时间兜底清理，单位秒。",
    "default": 600
  },
  "level_limit": {
    "description": "等级限制",
    "type": "object",
    "hint": "开启后，低于最低 QQ 等级或未获取到等级的加群请求不会进入关键词审核流程。",
    "obvious_hint": true,
    "items": {
      "enabled": {
        "description": "启用等级限制",
        "type": "bool",
        "hint": "开启后检查申请人的 QQ 等级。",
        "default": false
      },
      "min_level": {
        "description": "最低等级限制",
        "type": "int",
        "hint": "申请人 QQ 等级低于该值时视为不满足等级限制。",
        "default": 0
      },
      "reject_low_level": {
        "description": "直接拒绝低等级请求",
        "type": "bool",
        "hint": "关闭时不处理低等级或未获取到等级的请求；开启时直接拒绝这些请求。",
        "default": false
      },
      "reject_reason": {
        "description": "等级限制拒绝消息",
        "type": "string",
        "hint": "直接拒绝低等级请求时发送给申请人的消息。支持占位符：%group_id%、%group_name%、%user_id%、%user_name%、%user_level%、%min_level%、%level_reason%。",
        "default": "您的 QQ 等级过低，未通过本群自动审核。"
      }
    }
  },
  "accept_rules": {
    "description": "同意关键词规则",
    "type": "template_list",
    "hint": "按群配置自动同意关键词。适用群号填 default 表示默认规则；如果某个群配置了专属同意规则，该群只使用自己的规则，不再继承 default。",
    "default": [
      {
        "__template_key": "accept_rule",
        "enabled": true,
        "group_ids": ["default"],
        "category": "B站",
        "keywords": ["up", "哔", "哩", "小破", "站", "bi", "li", "bl"]
      },
      {
        "__template_key": "accept_rule",
        "enabled": true,
        "group_ids": ["default"],
        "category": "抖音",
        "keywords": ["抖", "音", "dy", "符"]
      },
      {
        "__template_key": "accept_rule",
        "enabled": true,
        "group_ids": ["default"],
        "category": "GitHub",
        "keywords": ["github", "gh"]
      }
    ],
    "templates": {
      "accept_rule": {
        "name": "同意规则",
        "hint": "同一群号下可以添加多条规则，分类用于统计来源。",
        "display_item": "category",
        "hide_hint_in_list": true,
        "items": {
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "group_ids": {
            "description": "适用群号列表",
            "type": "list",
            "hint": "填 default 表示默认规则；也可以填写多个具体群号，让同一条规则同时作用于多个群。",
            "default": ["default"]
          },
          "category": {
            "description": "来源分类",
            "type": "string",
            "hint": "匹配成功后写入入群统计，例如 B站、抖音、GitHub。",
            "default": "新分类"
          },
          "keywords": {
            "description": "同意关键词",
            "type": "list",
            "hint": "申请验证消息命中任一关键词即自动同意，不区分大小写。",
            "default": []
          }
        }
      }
    }
  },
  "reject_rules": {
    "description": "拒绝关键词规则",
    "type": "template_list",
    "hint": "按群配置自动拒绝关键词。适用群号填 default 表示默认规则；如果某个群配置了专属拒绝规则，该群只使用自己的规则，不再继承 default。拒绝优先级高于同意。",
    "default": [
      {
        "__template_key": "reject_rule",
        "enabled": true,
        "group_ids": ["default"],
        "keywords": ["广告", "代练", "加群", "互粉", "卖茶", "朋友推荐", "不知道"]
      }
    ],
    "templates": {
      "reject_rule": {
        "name": "拒绝规则",
        "hint": "同一群号下可以添加多条拒绝规则。",
        "hide_hint_in_list": true,
        "items": {
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "group_ids": {
            "description": "适用群号列表",
            "type": "list",
            "hint": "填 default 表示默认规则；也可以填写多个具体群号，让同一条规则同时作用于多个群。",
            "default": ["default"]
          },
          "keywords": {
            "description": "拒绝关键词",
            "type": "list",
            "hint": "申请验证消息命中任一关键词即自动拒绝，不区分大小写。",
            "default": []
          }
        }
      }
    }
  },
  "divide_group": {
    "description": "分群控制",
    "type": "object",
    "hint": "分群控制设置",
    "obvious_hint": true,
    "items": {
      "block_method": {
        "description": "阻止模式",
        "type": "string",
        "hint": "设置黑白名单模式",
        "default": "blacklist",
        "options": ["blacklist", "whitelist"]
      },
      "control_list": {
        "description": "黑/白名单列表",
        "type": "list",
        "hint": "在这些群聊里 禁用/启用 插件，填写群号(group_id)",
        "default": []
      },
      "disabled_statistics": {
        "description": "统计图表禁用群聊",
        "type": "list",
        "hint": "设置哪些群聊禁用加群统计功能，填写群号(group_id)",
        "default": []
      }
    }
  },
  "notice": {
    "description": "通知项",
    "type": "object",
    "hint": "通知项，每个列表元素均为SID，其中 origin 表示消息源群聊",
    "items": {
      "accept_notice": {
        "description": "同意消息通知",
        "type": "list",
        "hint": "消息通知会话，填SID（使用 /sid 获取），origin 表示消息源群聊，留空不通知（请务必修改默认配置）",
        "default": ["origin", "default:GroupMessage:12345678", "default:FriendMessage:12345678"]
      },
      "reject_notice": {
        "description": "拒绝消息通知",
        "type": "list",
        "hint": "消息群通知会话，填SID（使用 /sid 获取），origin 表示消息源群聊，留空不通知（请务必修改默认配置）",
        "default": ["origin", "default:GroupMessage:12345678", "default:FriendMessage:12345678"]
      },
      "increase_notice": {
        "description": "手动同意消息通知",
        "type": "list",
        "hint": "消息群通知会话，填SID（使用 /sid 获取），origin 表示消息源群聊，留空不通知（请务必修改默认配置）",
        "default": ["origin", "default:GroupMessage:12345678", "default:FriendMessage:12345678"]
      },
      "decrease_notice": {
        "description": "退群消息通知",
        "type": "list",
        "hint": "消息群通知会话，填SID（使用 /sid 获取），origin 表示消息源群聊，留空不通知（请务必修改默认配置）",
        "default": ["origin", "default:GroupMessage:12345678", "default:FriendMessage:12345678"]
      }
    }
  },
  "message_templates": {
    "description": "消息模板",
    "type": "object",
    "hint": "消息模板均支持占位符。每个模板列表中，适用群号列表填 default 表示默认模板；也可以填写多个具体群号，让同一条模板同时作用于多个群。",
    "items": {
      "welcome_msg": {
        "description": "自动同意欢迎语",
        "type": "template_list",
        "default": [
          {
            "__template_key": "message",
            "group_ids": ["default"],
            "text": "欢迎新成员！通过自动审核"
          }
        ],
        "templates": {
          "message": {
            "name": "欢迎语",
            "hide_hint_in_list": true,
            "items": {
              "group_ids": {
                "description": "适用群号列表",
                "type": "list",
                "hint": "填 default 表示默认模板；也可以填写多个具体群号，让同一条模板同时作用于多个群。",
                "default": ["default"]
              },
              "text": {
                "description": "消息内容",
                "type": "text",
                "hint": "支持 %group_id%、%user_id%、%user_name%、%category%、%comment%。",
                "default": "欢迎新成员！通过自动审核"
              }
            }
          }
        }
      },
      "reject_reason": {
        "description": "自动拒绝理由",
        "type": "template_list",
        "default": [
          {
            "__template_key": "message",
            "group_ids": ["default"],
            "text": "检测到关键词%key%，拒绝申请"
          }
        ],
        "templates": {
          "message": {
            "name": "拒绝理由",
            "hide_hint_in_list": true,
            "items": {
              "group_ids": {
                "description": "适用群号列表",
                "type": "list",
                "hint": "填 default 表示默认模板；也可以填写多个具体群号，让同一条模板同时作用于多个群。",
                "default": ["default"]
              },
              "text": {
                "description": "消息内容",
                "type": "text",
                "hint": "支持 %group_id%、%user_id%、%user_name%、%key%。",
                "default": "检测到关键词%key%，拒绝申请"
              }
            }
          }
        }
      },
      "decrease_msg": {
        "description": "退群提示",
        "type": "template_list",
        "default": [
          {
            "__template_key": "message",
            "group_ids": ["default"],
            "text": "呜呜呜~ %user_name%(%user_id%)退出了群聊"
          }
        ],
        "templates": {
          "message": {
            "name": "退群提示",
            "hide_hint_in_list": true,
            "items": {
              "group_ids": {
                "description": "适用群号列表",
                "type": "list",
                "hint": "填 default 表示默认模板；也可以填写多个具体群号，让同一条模板同时作用于多个群。",
                "default": ["default"]
              },
              "text": {
                "description": "消息内容",
                "type": "text",
                "hint": "支持 %group_id%、%user_id%、%user_name%。",
                "default": "呜呜呜~ %user_name%(%user_id%)退出了群聊"
              }
            }
          }
        }
      },
      "increase_msg": {
        "description": "手动同意欢迎语",
        "type": "template_list",
        "default": [
          {
            "__template_key": "message",
            "group_ids": ["default"],
            "text": "恭喜你通过人工审核，欢迎入群~"
          }
        ],
        "templates": {
          "message": {
            "name": "手动同意欢迎语",
            "hide_hint_in_list": true,
            "items": {
              "group_ids": {
                "description": "适用群号列表",
                "type": "list",
                "hint": "填 default 表示默认模板；也可以填写多个具体群号，让同一条模板同时作用于多个群。",
                "default": ["default"]
              },
              "text": {
                "description": "消息内容",
                "type": "text",
                "hint": "支持 %group_id%、%user_id%、%user_name%。",
                "default": "恭喜你通过人工审核，欢迎入群~"
              }
            }
          }
        }
      }
    }
  }
}
